# Runtime artifacts — the skills GENERATE these into a target project; they are never authored here.
ledger.json
graph.json
*.skill
.audit/
docs/audits/

# NOTE what is deliberately NOT ignored: plugins/. It is build output, and it is committed, because
# a marketplace installs straight from the repo — there is nowhere else for it to live. That is what
# `python scripts/build.py --check` is for: it fails CI if the committed output drifts from src/.

node_modules/
__pycache__/
*.pyc
.venv/
venv/
.DS_Store
